{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://localhost:3001/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      },
      {
        "source": "/admin/:path*",
        "destination": "http://localhost:3001/admin/:path*",
        "regex": "^/admin(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/the-loai/[slug]",
      "regex": "^/the\\-loai/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/the\\-loai/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/truyen/[slug]",
      "regex": "^/truyen/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/truyen/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/truyen/[slug]/chuong/[ch]",
      "regex": "^/truyen/([^/]+?)/chuong/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug",
        "nxtPch": "nxtPch"
      },
      "namedRegex": "^/truyen/(?<nxtPslug>[^/]+?)/chuong/(?<nxtPch>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/bang-xep-hang",
      "regex": "^/bang\\-xep\\-hang(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/bang\\-xep\\-hang(?:/)?$"
    },
    {
      "page": "/robots.txt",
      "regex": "^/robots\\.txt(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/robots\\.txt(?:/)?$"
    },
    {
      "page": "/sitemap.xml",
      "regex": "^/sitemap\\.xml(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sitemap\\.xml(?:/)?$"
    },
    {
      "page": "/the-loai",
      "regex": "^/the\\-loai(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/the\\-loai(?:/)?$"
    },
    {
      "page": "/tim-kiem",
      "regex": "^/tim\\-kiem(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tim\\-kiem(?:/)?$"
    },
    {
      "page": "/tu-sach",
      "regex": "^/tu\\-sach(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/tu\\-sach(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}